      <table>
        <view>
          <datasources>
            <datasource caption='germany.dashboard' name='federated.1a3l4ir0jr5sm113tfixz1sml9vi' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.1a3l4ir0jr5sm113tfixz1sml9vi'>
            <column caption='Area de trabajo' datatype='string' name='[Calculation_2133886550204423]' role='dimension' type='nominal' user:unnamed='Empleabilidad por Area de trabajo'>
              <calculation class='tableau' formula='//Area de trabajo&#13;&#10;[Field Of Work (group) 1]' />
            </column>
            <column caption='Horas de Trabajo' datatype='string' name='[Calculation_2405461033213955]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [working_hours] &lt; 20 THEN &quot;Less than 20&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 41 THEN &quot;21-40&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 61 THEN &quot;41-60&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 81 THEN &quot;61-80&quot;&#13;&#10;ELSE &quot;Over 80&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Field Of Work (group) 1]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[field of work]' new-bin='true'>
                <bin default-name='false' value='&quot;Food Industry, Industry Technical Service and 6 more&quot;'>
                  <value>%null%</value>
                  <value>&quot;Food Industry&quot;</value>
                  <value>&quot;Industry Technical Service&quot;</value>
                  <value>&quot;Mixed practice&quot;</value>
                  <value>&quot;Other&quot;</value>
                  <value>&quot;R&amp;D&quot;</value>
                  <value>&quot;Slaughterhouse&quot;</value>
                  <value>&quot;University&quot;</value>
                  <value>&quot;Zoo Animals&quot;</value>
                </bin>
              </calculation>
            </column>
            <column-instance column='[status of employment]' derivation='Count' name='[cnt:status of employment:qk]' pivot='key' type='quantitative' />
            <column caption='Federal State' datatype='string' name='[federal state]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
              <semantic-values semantic-role='[State].[Name]'>
                <semantic-value key='&quot;Saxony (Sachsen)&quot;' value='&quot;Saxony&quot;' />
              </semantic-values>
            </column>
            <column caption='Field Of Work' datatype='string' name='[field of work]' role='dimension' type='nominal' />
            <column caption='Gender' datatype='string' name='[gender]' role='dimension' type='nominal' />
            <column caption='Income' datatype='string' name='[income]' role='dimension' type='nominal' />
