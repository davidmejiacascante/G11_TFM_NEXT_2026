            <column caption='Burnout Score' datatype='integer' name='[Burnout_Score]' role='measure' type='quantitative' />
            <column caption='Porcentaje de BurnOut' datatype='real' name='[Calculation_2405461029724160]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Burnout_Score])/TOTAL(COUNT([Burnout_Score]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Federal State' datatype='string' name='[federal state]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
