            <column caption='Rango de Edad' datatype='string' name='[Calculation_0820241221050368]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age] &lt; 25 THEN &quot;Under 25&quot;&#13;&#10;ELSEIF [age] &lt;= 40 THEN &quot;25-40&quot;&#13;&#10;ELSEIF [age] &lt;= 55 THEN &quot;41-55&quot;&#13;&#10;ELSEIF [age] &lt;= 65 THEN &quot;56-65&quot;&#13;&#10;ELSE &quot;65+&quot;&#13;&#10;END' />
            </column>
            <column caption='Condición Laboral' datatype='string' name='[Calculation_2124541797167104]' role='dimension' type='nominal' user:unnamed='Burnout por condición laboral'>
              <calculation class='tableau' formula='//Condición Laboral&#13;&#10;[Status Of Employment (group)]' />
            </column>
            <column datatype='string' name='[Status Of Employment (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[status of employment]' new-bin='true'>
                <bin default-name='true' value='&quot;Employed &amp; Self-Employed&quot;'>
                  <value>&quot;Employed&quot;</value>
                  <value>&quot;Self-Employed&quot;</value>
                </bin>
                <bin default-name='true' value='&quot;Medical Leave, Other, Parental Leave and 1 more&quot;'>
                  <value>&quot;Medical Leave&quot;</value>
                  <value>&quot;Other&quot;</value>
                  <value>&quot;Parental Leave&quot;</value>
                  <value>&quot;Unemployed by Choice&quot;</value>
                </bin>
              </calculation>
