            <column caption='Rango de Edad' datatype='string' name='[Calculation_0820241221050368]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age] &lt; 25 THEN &quot;Under 25&quot;&#13;&#10;ELSEIF [age] &lt;= 40 THEN &quot;25-40&quot;&#13;&#10;ELSEIF [age] &lt;= 55 THEN &quot;41-55&quot;&#13;&#10;ELSEIF [age] &lt;= 65 THEN &quot;56-65&quot;&#13;&#10;ELSE &quot;65+&quot;&#13;&#10;END' />
            </column>
            <column caption='Clasificación BurnOut' datatype='string' name='[Calculation_2405461031772162]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Burnout_Score] = 1 THEN &quot;Con Burnout&quot;&#13;&#10;ELSE &quot;Sin Burnout&quot;&#13;&#10;END' />
            </column>
            <column caption='Horas de Trabajo' datatype='string' name='[Calculation_2405461033213955]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [working_hours] &lt; 20 THEN &quot;Less than 20&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 41 THEN &quot;21-40&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 61 THEN &quot;41-60&quot;&#13;&#10;ELSEIF [working_hours] &lt;= 81 THEN &quot;61-80&quot;&#13;&#10;ELSE &quot;Over 80&quot;&#13;&#10;END' />
            </column>
            <column caption='Eri 4' datatype='string' name='[ERI_4]' role='dimension' type='nominal' />
